<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/balance_widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_bg_glass"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@mipmap/ic_launcher" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="EdgePay Balance"
            android:textColor="#1C1C1E"
            android:textSize="13sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WALLET"
                android:textColor="#636366"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/balance_widget_wallet"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹1,000"
                android:textColor="#007AFF"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="BANK"
                android:textColor="#636366"
                android:textSize="10sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/balance_widget_bank"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="₹ ••••"
                android:textColor="#5856D6"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <TextView
        android:id="@+id/balance_widget_spent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Today: ₹0 spent"
        android:textColor="#FF9500"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginTop="10dp" />

    <TextView
        android:id="@+id/balance_widget_last_tx"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No recent transactions"
        android:textColor="#AEAEB2"
        android:textSize="11sp"
        android:maxLines="1"
        android:ellipsize="end"
        android:layout_marginTop="6dp" />
</LinearLayout>
